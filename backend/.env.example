# =============================
# TOHUTOU backend env template
# Copy this file to backend/.env
# =============================

# Database
DATABASE_URL=postgresql+asyncpg://tohutou:tohutou_dev@localhost:5432/tohutou_db

# JWT
SECRET_KEY=change-me-with-at-least-32-characters-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AES-256 (64 hex chars exactly)
AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CORS (JSON array format)
CORS_ORIGINS=["http://localhost:3000"]

# Super admin seed (optional)
ADMIN_PHONE=0143126900
ADMIN_PASSWORD=change-me-admin-password
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin

# S3/Object storage (optional)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

